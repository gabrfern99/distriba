model Supplier {
  id        String   @id @default(cuid())
  name      String
  document  String?
  phone     String?
  email     String?
  address   String?
  notes     String?
  isActive  Boolean  @default(true)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrders PurchaseOrder[]

  @@index([tenantId])
  @@map("suppliers")
}
